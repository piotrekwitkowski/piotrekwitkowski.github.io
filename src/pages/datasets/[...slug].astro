---
import Layout from "../../layouts/Layout.astro";
import DatasetExplorer from "../../components/DatasetExplorer";

export function getStaticPaths() {
  return [
    { params: { slug: "airport-coordinates" } },
    { params: { slug: "bgp-asnames" } },
    { params: { slug: "cloudfront-edge-locations" } },
    { params: { slug: "cloudfront-embedded-pops" } },
    { params: { slug: "domain-registry" } },
    { params: { slug: "icloud-private-relay" } },
    { params: { slug: "ieee-oui" } },
    { params: { slug: "root-servers" } },
  ];
}

const { slug } = Astro.params;
---

<Layout title={`Dataset: ${slug}`}>
  <DatasetExplorer datasetName={slug} client:load />
</Layout>
