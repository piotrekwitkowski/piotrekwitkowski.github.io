---
import "@cloudscape-design/global-styles/index.css";

interface Props {
  title?: string;
}
const { title = "Piotrek's Toolbox" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href="/static/fonts/open-sans-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/static/fonts/open-sans-700-normal.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <style is:inline>
      @font-face { font-family: 'Open Sans'; font-weight: 300; font-style: normal; font-display: block; src: url('/static/fonts/open-sans-300-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 300; font-style: italic; font-display: block; src: url('/static/fonts/open-sans-300-italic.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 400; font-style: normal; font-display: block; src: url('/static/fonts/open-sans-400-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 400; font-style: italic; font-display: block; src: url('/static/fonts/open-sans-400-italic.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 700; font-style: normal; font-display: block; src: url('/static/fonts/open-sans-700-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 700; font-style: italic; font-display: block; src: url('/static/fonts/open-sans-700-italic.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 800; font-style: normal; font-display: block; src: url('/static/fonts/open-sans-800-normal.woff2') format('woff2'); }
      @font-face { font-family: 'Open Sans'; font-weight: 800; font-style: italic; font-display: block; src: url('/static/fonts/open-sans-800-italic.woff2') format('woff2'); }
      html, body, #app { margin: 0; padding: 0; height: 100%; }
    </style>
  </head>
  <body>
    <script is:inline>
      (function() {
        var mode = localStorage.getItem("theme-mode") || "system";
        var dark = mode === "dark" || (mode === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
        if (dark) document.body.classList.add("awsui-dark-mode");
      })();
    </script>
    <slot />
  </body>
</html>
