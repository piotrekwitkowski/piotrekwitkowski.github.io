---
import "@cloudscape-design/global-styles/index.css";

interface Props {
  title?: string;
}
const { title = "Piotrek's Toolbox" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      /* Cloudscape expects full-height layout */
      html, body, #app {
        margin: 0;
        padding: 0;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <script is:inline>
      (function() {
        var mode = localStorage.getItem("theme-mode") || "system";
        var dark = mode === "dark" || (mode === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
        if (dark) document.body.classList.add("awsui-dark-mode");
      })();
    </script>
    <slot />
  </body>
</html>
